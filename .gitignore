node_modules/

# Secrets - never commit
.env
.env.*
.env.all
**/.env.all
*.key
*.pem
# session cookies / tokens (leftover prototype debug artifacts)
cookies*.txt
**/cookies*.txt
*.cookies

# Databases / runtime data dumps
*.sqlite3
*.sqlite3-wal
*.sqlite3-shm
*.db
*-wal
*-shm

# Logs
logs/
*.log

# Python
__pycache__/
*.pyc
