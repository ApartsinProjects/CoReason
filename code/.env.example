# CoReason Environment Variables
NODE_ENV=development
PORT=3000
SESSION_SECRET=change-me-to-random-string

# Database (SQLite for local, PostgreSQL for staging/prod)
# DATABASE_URL=postgresql://user:pass@host:5432/coreason

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# LLM Providers (ModelMesh)
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
COHERE_API_KEY=
ANTHROPIC_API_KEY=

# Cloudflare (file storage)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
