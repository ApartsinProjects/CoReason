{
  "name": "coreason",
  "version": "1.0.0",
  "description": "CoReasoning Lab — AI co-reasoning assessment platform",
  "main": "code/server/index.js",
  "scripts": {
    "start": "cd code && npm start",
    "dev": "cd code && npm run dev",
    "build": "node build-content.js",
    "build:watch": "node build-content.js --watch",
    "db:migrate": "cd code && npm run db:migrate",
    "db:rollback": "cd code && npm run db:rollback",
    "db:seed": "cd code && npm run db:seed",
    "db:reset": "cd code && npm run db:reset",
    "import": "cd code && npm run import",
    "test": "cd code && npm test",
    "test:unit": "cd code && npm run test:unit",
    "test:integration": "cd code && npm run test:integration",
    "test:e2e": "cd code && npx playwright test",
    "test:all": "cd code && npm run test:all",
    "lint": "cd code && npm run lint",
    "lint:fix": "cd code && npm run lint:fix",
    "format": "cd code && npm run format",
    "docker:dev": "docker compose -f docker/docker-compose.dev.yml up --build",
    "docker:prod": "docker compose -f docker/docker-compose.yml up --build -d"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "compression": "^1.7.4",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-session": "^1.18.0",
    "glob": "^10.3.0",
    "helmet": "^8.0.0",
    "js-yaml": "^4.1.0",
    "knex": "^3.1.0",
    "lru-cache": "^11.0.0",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.13.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "eslint": "^9.12.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.3.0",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
